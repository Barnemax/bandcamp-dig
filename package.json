{
  "name": "bandcamp-dig",
  "type": "module",
  "version": "1.0.1",
  "private": true,
  "description": "Dig better on Bandcamp. Sort items in playlists, track new releases, provide dark mode and more.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint:css": "stylelint \"src/**/*.scss\" \"public/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.scss\" \"public/**/*.css\" --fix",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@barnemax/bandcamp-types": "^0.1.5",
    "eslint": "^9.39.4",
    "sass": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wxt": "^0.20.18"
  }
}
